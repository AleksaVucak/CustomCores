# =============================================================================
# CustomCore — Git ignore rules
# Keeps secrets, local environment files, uploads, and tooling junk out of Git.
# =============================================================================

# -----------------------------------------------------------------------------
# Application secrets and local configuration
# Real database credentials must never be committed. Use database.example.php.
# -----------------------------------------------------------------------------
/config/database.php
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Uploaded user and admin content (directory placeholders use .gitkeep later)
# -----------------------------------------------------------------------------
/uploads/consultation/*
!/uploads/consultation/.gitkeep
/uploads/products/*
!/uploads/products/.gitkeep

# -----------------------------------------------------------------------------
# PHP / Composer (Composer is not required; ignore if introduced locally)
# -----------------------------------------------------------------------------
/vendor/
composer.phar
composer.lock

# -----------------------------------------------------------------------------
# Logs, caches, and temporary files
# -----------------------------------------------------------------------------
*.log
logs/
cache/
tmp/
temp/
*.cache
*.tmp
*.temp
*.bak
*.swp
*~

# -----------------------------------------------------------------------------
# Operating system files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Editor and IDE settings
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
*.code-workspace

# -----------------------------------------------------------------------------
# Local development / server artefacts
# -----------------------------------------------------------------------------
.phpunit.result.cache
.php-cs-fixer.cache
.phplint-cache
*.pid
*.seed

# -----------------------------------------------------------------------------
# Local database dumps that may contain private customer data
# Intentional schema and seed SQL files under /database/ remain tracked.
# -----------------------------------------------------------------------------
*.sql.gz
*.sql.bak
/database/local/
/database/exports/
